# ====================================================================
# MEM-AGENT EXAMPLE CONFIGURATION
# ====================================================================
# Save this file as "config.yaml" and edit as needed.
#
# Quick start:
# 1. Copy this file to "config.yaml"
# 2. Update the core settings below
# 3. See docs/CONFIG_GUIDE.md for detailed guidance
# ====================================================================

# CORE SETTINGS
# --------------------------------------------------------------------

# Usage mode: "personal" or "business"
usage_mode: "personal"

# LLM settings
llm:
  model: "granite4:3b"               # Ollama model name
  base_url: "http://localhost:11434" # Ollama API URL
  temperature: 0.7                   # 0.0 - 1.0
  max_tokens: 500

# Memory settings
memory:
  backend: "json"                    # "json" or "sql"
  json_dir: "memories"
  db_path: "memories.db"

# Prompt settings
prompt:
  template: "personal_assistant"
  variables:
    user_name: "User"
    tone: "friendly"


# ADVANCED SETTINGS (OPTIONAL)
# --------------------------------------------------------------------

personal:
  user_name: "User"
  enable_reminders: true
  enable_personal_notes: true
  privacy_level: "high"
  share_data: false

business:
  company_name: "Your Company"
  departments: ["Customer Service", "Sales", "Technical Support"]
  enable_multi_user: true
  enable_reporting: true
  security_level: "high"

knowledge_base:
  enabled: true
  auto_load: true
  default_kb: "ecommerce"            # ecommerce, tech_support
  search_limit: 5

response:
  use_knowledge_base: true
  use_memory: true
  recent_conversations_limit: 5

logging:
  enabled: true
  level: "INFO"                      # DEBUG, INFO, WARNING, ERROR
  file: "mem_agent.log"

security:
  filter_sensitive_data: true
  rate_limit:
    enabled: true
    max_requests_per_minute: 60

# ====================================================================
# EXAMPLES
# ====================================================================

# Minimal personal setup:
# usage_mode: "personal"
# llm:
#   model: "granite4:3b"
# memory:
#   backend: "json"

# Recommended business setup:
# usage_mode: "business"
# llm:
#   model: "granite4:3b"
# memory:
#   backend: "sql"
# knowledge_base:
#   enabled: true
